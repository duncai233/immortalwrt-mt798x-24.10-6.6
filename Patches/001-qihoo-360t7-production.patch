diff --git a/target/linux/mediatek/filogic/base-files/etc/uci-defaults/zz_qihoo_360t7-defaults b/target/linux/mediatek/filogic/base-files/etc/uci-defaults/zz_qihoo_360t7-defaults
new file mode 100755
--- /dev/null
+++ b/target/linux/mediatek/filogic/base-files/etc/uci-defaults/zz_qihoo_360t7-defaults
@@ -0,0 +1,97 @@
+#!/bin/sh
+
+. /lib/functions.sh
+
+board="$(board_name)"
+[ "$board" = "qihoo,360t7" ] || exit 0
+
+[ -s /etc/board.json ] || /bin/board_detect /etc/board.json 2>/dev/null || true
+
+if ! uci -q get system.@system[0] >/dev/null || ! uci -q get network.lan >/dev/null; then
+	/bin/config_generate 2>/dev/null || true
+fi
+
+uci -q get system.@system[0] >/dev/null || uci -q add system system >/dev/null
+uci -q batch <<-EOF
+	set system.@system[0].hostname='360T7'
+	commit system
+EOF
+
+if ! uci -q get network.lan >/dev/null || ! uci -q get network.wan >/dev/null; then
+	uci -q batch <<-EOF
+		delete network.br_lan
+		delete network.lan
+		delete network.wan
+		delete network.wan6
+		set network.br_lan='device'
+		set network.br_lan.name='br-lan'
+		set network.br_lan.type='bridge'
+		add_list network.br_lan.ports='lan1'
+		add_list network.br_lan.ports='lan2'
+		add_list network.br_lan.ports='lan3'
+		set network.lan='interface'
+		set network.lan.device='br-lan'
+		set network.lan.proto='static'
+		set network.lan.ipaddr='192.168.1.1'
+		set network.lan.netmask='255.255.255.0'
+		set network.lan.ip6assign='60'
+		set network.wan='interface'
+		set network.wan.device='wan'
+		set network.wan.proto='dhcp'
+		set network.wan6='interface'
+		set network.wan6.device='wan'
+		set network.wan6.proto='dhcpv6'
+		commit network
+	EOF
+else
+	uci -q batch <<-EOF
+		set network.lan.device='br-lan'
+		set network.lan.proto='static'
+		set network.lan.ipaddr='192.168.1.1'
+		set network.lan.netmask='255.255.255.0'
+		set network.lan.ip6assign='60'
+		set network.wan.device='wan'
+		set network.wan.proto='dhcp'
+		set network.wan6.device='wan'
+		set network.wan6.proto='dhcpv6'
+		commit network
+	EOF
+fi
+
+uci -q batch <<-EOF
+	set dhcp.lan='dhcp'
+	set dhcp.lan.interface='lan'
+	set dhcp.lan.start='100'
+	set dhcp.lan.limit='150'
+	set dhcp.lan.leasetime='12h'
+	delete dhcp.lan.ignore
+	set dhcp.lan.dhcpv4='server'
+	set dhcp.wan='dhcp'
+	set dhcp.wan.interface='wan'
+	set dhcp.wan.ignore='1'
+	commit dhcp
+EOF
+
+uci -q delete turboacc.config.fastpath_mh_eth_hnat_ap
+uci -q commit turboacc
+
+if [ ! -s /etc/config/wireless ] || ! uci -q show wireless | grep -q '=wifi-device'; then
+	modprobe mt_wifi 2>/dev/null || true
+	sleep 2
+	/sbin/wifi config 2>/dev/null || true
+fi
+
+if uci -q show wireless | grep -q '=wifi-device'; then
+	if [ -x /usr/sbin/360t7-wifi-profile ]; then
+		wifi_profile="$(sed -n 's/^profile=//p' /etc/360t7-wifi-profile 2>/dev/null | head -n 1)"
+		[ -n "$wifi_profile" ] || wifi_profile="stable"
+		/usr/sbin/360t7-wifi-profile "$wifi_profile" no-reload 2>/dev/null || true
+	fi
+	/sbin/wifi up 2>/dev/null || true
+fi
+
+[ -x /etc/init.d/network ] && /etc/init.d/network enable
+[ -x /etc/init.d/dnsmasq ] && /etc/init.d/dnsmasq enable
+[ -x /etc/init.d/uhttpd ] && /etc/init.d/uhttpd enable
+[ -x /etc/init.d/dropbear ] && /etc/init.d/dropbear enable
+exit 0
diff --git a/target/linux/mediatek/filogic/base-files/usr/sbin/360t7-wifi-profile b/target/linux/mediatek/filogic/base-files/usr/sbin/360t7-wifi-profile
new file mode 100755
--- /dev/null
+++ b/target/linux/mediatek/filogic/base-files/usr/sbin/360t7-wifi-profile
@@ -0,0 +1,111 @@
+#!/bin/sh
+set -u
+
+CONFIG_FILE="/etc/360t7-wifi-profile"
+PROFILE="${1:-}"
+RELOAD="1"
+
+read_default_profile() {
+	sed -n 's/^profile=//p' "$CONFIG_FILE" 2>/dev/null | head -n 1
+}
+
+case "$PROFILE" in
+	"" )
+		PROFILE="$(read_default_profile)"
+		;;
+	no-reload|--no-reload )
+		PROFILE="$(read_default_profile)"
+		RELOAD="0"
+		;;
+esac
+
+case "${2:-}" in
+	no-reload|--no-reload)
+		RELOAD="0"
+		;;
+esac
+
+[ -n "$PROFILE" ] || PROFILE="stable"
+
+case "$PROFILE" in
+	stable|compat)
+		PROFILE="stable"
+		;;
+	performance|default|upstream)
+		PROFILE="performance"
+		;;
+	*)
+		echo "Usage: 360t7-wifi-profile [stable|performance] [no-reload]" >&2
+		exit 2
+		;;
+esac
+
+if ! uci -q show wireless | grep -q '=wifi-device'; then
+	modprobe mt_wifi 2>/dev/null || true
+	sleep 2
+	/sbin/wifi config 2>/dev/null || true
+fi
+
+found=0
+for dev in $(uci -q show wireless | sed -n 's/^wireless\.\([^.]*\)=wifi-device$/\1/p'); do
+	type="$(uci -q get wireless."$dev".type 2>/dev/null || true)"
+	[ "$type" = "mtwifi" ] || continue
+
+	band="$(uci -q get wireless."$dev".band 2>/dev/null || true)"
+	[ -n "$band" ] || continue
+
+	found=1
+	uci -q batch <<-EOF
+		set wireless.$dev.country='CN'
+		set wireless.$dev.txpower='100'
+		set wireless.$dev.mu_beamformer='1'
+		set wireless.$dev.serialize='1'
+		set wireless.$dev.wapp='0'
+		set wireless.$dev.bandsteering='0'
+		set wireless.$dev.twt='0'
+	EOF
+
+	case "$PROFILE:$band" in
+		stable:2g)
+			uci -q batch <<-EOF
+				set wireless.$dev.channel='auto'
+				set wireless.$dev.htmode='HE20'
+				set wireless.$dev.noscan='0'
+			EOF
+			;;
+		stable:5g)
+			uci -q batch <<-EOF
+				set wireless.$dev.channel='36'
+				set wireless.$dev.htmode='HE80'
+				set wireless.$dev.noscan='0'
+			EOF
+			;;
+		performance:2g)
+			uci -q batch <<-EOF
+				set wireless.$dev.channel='auto'
+				set wireless.$dev.htmode='HE40'
+				set wireless.$dev.noscan='1'
+			EOF
+			;;
+		performance:5g)
+			uci -q batch <<-EOF
+				set wireless.$dev.channel='36'
+				set wireless.$dev.htmode='HE160'
+				set wireless.$dev.noscan='0'
+			EOF
+			;;
+	esac
+done
+
+[ "$found" = "1" ] || {
+	echo "No mtwifi device found." >&2
+	exit 1
+}
+
+uci -q commit wireless
+echo "360T7 WiFi profile applied: $PROFILE"
+
+if [ "$RELOAD" = "1" ]; then
+	/sbin/wifi reload >/dev/null 2>&1 || /sbin/wifi up >/dev/null 2>&1 || true
+fi
+exit 0
